{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "$HOME/.helpful/tmux/set-agent-state.sh @codex working",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "$HOME/.helpful/tmux/set-agent-state.sh @codex done",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "SUPERSET_AGENT_ID=codex \"/Users/aidan/.superset/hooks/notify.sh\""
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "command": "$HOME/.helpful/tmux/set-agent-state.sh @codex working",
            "type": "command"
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "command": "$HOME/.helpful/tmux/set-agent-state.sh @codex working",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "$HOME/.helpful/tmux/set-agent-state.sh @codex working",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "SUPERSET_AGENT_ID=codex \"/Users/aidan/.superset/hooks/notify.sh\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "SUPERSET_AGENT_ID=codex \"/Users/aidan/.superset/hooks/notify.sh\""
          }
        ]
      }
    ]
  }
}